#!/usr/bin/env python3

from __future__ import annotations

import argparse
import json
import os
import pathlib
import tempfile
import time
import urllib.error
import urllib.request


DEFAULT_API_BASE = os.environ.get("DEN_TELEGRAM_API_BASE", "https://api.telegram.org")
DEFAULT_BRIDGE_STATE_ROOT = pathlib.Path(
    os.environ.get("DEN_CODEX_BRIDGE_STATE_ROOT")
    or os.path.join(os.environ.get("XDG_STATE_HOME", os.path.expanduser("~/.local/state")), "den-codex")
)
DEFAULT_RELAY_STATE_ROOT = pathlib.Path(
    os.environ.get("DEN_TELEGRAM_RELAY_STATE_ROOT")
    or os.path.join(os.environ.get("XDG_STATE_HOME", os.path.expanduser("~/.local/state")), "den-telegram")
)


class RelayError(RuntimeError):
    pass


def atomic_write_json(path: pathlib.Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", dir=path.parent, delete=False, encoding="utf-8") as handle:
        json.dump(payload, handle, indent=2, sort_keys=True)
        handle.write("\n")
        temp_path = pathlib.Path(handle.name)
    temp_path.replace(path)


def read_json(path: pathlib.Path) -> dict:
    return json.loads(path.read_text(encoding="utf-8"))


class RelayState:
    def __init__(self, path: pathlib.Path):
        self.path = path
        if path.exists():
            self.data = read_json(path)
        else:
            self.data = {"offset": 0, "updated_at": None}
            self.save()

    @property
    def offset(self) -> int:
        return int(self.data.get("offset", 0))

    @offset.setter
    def offset(self, value: int) -> None:
        self.data["offset"] = int(value)

    def save(self) -> None:
        self.data["updated_at"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
        atomic_write_json(self.path, self.data)


class TelegramBotApiClient:
    def __init__(self, token: str, api_base: str):
        self._base_url = f"{api_base.rstrip('/')}/bot{token}"

    def call(self, method: str, payload: dict | None = None) -> object:
        body = None
        headers = {}
        if payload is not None:
            body = json.dumps(payload).encode("utf-8")
            headers["Content-Type"] = "application/json"
        request = urllib.request.Request(
            f"{self._base_url}/{method}",
            data=body,
            headers=headers,
            method="POST" if body is not None else "GET",
        )
        with urllib.request.urlopen(request, timeout=60) as response:
            data = json.loads(response.read().decode("utf-8"))
        if not data.get("ok", False):
            raise RelayError(f"Telegram Bot API {method} failed: {data.get('description', 'unknown error')}")
        return data.get("result")


def normalize_command(raw: str) -> list[str]:
    pieces = raw.strip().split()
    if not pieces:
        return []
    command = pieces[0]
    if command.startswith("/"):
        command = command[1:]
    if "@" in command:
        command = command.split("@", 1)[0]
    return [command.lower(), *pieces[1:]]


def read_bridge_state(project: str, bridge_state_root: pathlib.Path) -> dict:
    path = bridge_state_root / project / "state.json"
    if not path.exists():
        raise RelayError(f"no bridge state found for project {project}")
    return read_json(path)


def post_bridge_wake(project: str, dispatch_id: int, bridge_state_root: pathlib.Path) -> dict:
    state = read_bridge_state(project, bridge_state_root)
    wake_port = state.get("wake_port")
    if not isinstance(wake_port, int):
        raise RelayError(f"bridge for project {project} is not exposing a wake port")
    body = json.dumps({"dispatch_id": dispatch_id}).encode("utf-8")
    request = urllib.request.Request(
        f"http://127.0.0.1:{wake_port}/wake",
        data=body,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(request, timeout=10) as response:
        return json.loads(response.read().decode("utf-8"))


def format_status(project: str, bridge_state_root: pathlib.Path) -> str:
    state = read_bridge_state(project, bridge_state_root)
    pending = state.get("pending_dispatch_ids") or []
    current = state.get("current_dispatch_id")
    lines = [
        f"Project: {project}",
        f"Status: {state.get('status', 'unknown')}",
        f"Thread: {state.get('thread_id') or 'none'}",
        f"Pending queue: {len(pending)}",
    ]
    if current is not None:
        lines.append(f"Current dispatch: #{current}")
    if state.get("last_error"):
        lines.append(f"Last error: {state['last_error']}")
    return "\n".join(lines)


def resolve_wake_args(args: list[str], default_project: str | None) -> tuple[str, int]:
    if len(args) == 1 and default_project:
        project = default_project
        dispatch_text = args[0]
    elif len(args) == 2:
        project, dispatch_text = args
    else:
        raise RelayError("usage: /wake <dispatch_id> or /wake <project> <dispatch_id>")
    try:
        dispatch_id = int(dispatch_text)
    except ValueError as exc:
        raise RelayError(f"invalid dispatch id: {dispatch_text}") from exc
    return project, dispatch_id


def resolve_status_args(args: list[str], default_project: str | None) -> str:
    if len(args) == 0 and default_project:
        return default_project
    if len(args) == 1:
        return args[0]
    raise RelayError("usage: /status or /status <project>")


def help_text(default_project: str | None) -> str:
    wake_usage = "/wake <dispatch_id>" if default_project else "/wake <project> <dispatch_id>"
    status_usage = "/status" if default_project else "/status <project>"
    return "\n".join(
        [
            "Supported commands:",
            wake_usage,
            status_usage,
            "/help",
        ]
    )


def handle_message(
    *,
    message: dict,
    client: TelegramBotApiClient,
    allowed_chat_ids: set[int],
    bridge_state_root: pathlib.Path,
    default_project: str | None,
) -> None:
    chat = message.get("chat", {})
    chat_id = chat.get("id")
    if not isinstance(chat_id, int):
        return
    if allowed_chat_ids and chat_id not in allowed_chat_ids:
        return
    text = message.get("text")
    if not isinstance(text, str):
        return

    parts = normalize_command(text)
    if not parts:
        return
    command, *args = parts
    try:
        if command == "wake":
            project, dispatch_id = resolve_wake_args(args, default_project)
            response = post_bridge_wake(project, dispatch_id, bridge_state_root)
            reply = f"Queued dispatch #{response.get('dispatch_id', dispatch_id)} for {project}."
        elif command == "status":
            project = resolve_status_args(args, default_project)
            reply = format_status(project, bridge_state_root)
        elif command == "help":
            reply = help_text(default_project)
        else:
            return
    except RelayError as exc:
        reply = str(exc)

    client.call(
        "sendMessage",
        {
            "chat_id": chat_id,
            "text": reply,
        },
    )


def run_poll(args: argparse.Namespace) -> int:
    client = TelegramBotApiClient(args.bot_token, args.telegram_api_base)
    relay_state = RelayState(pathlib.Path(args.relay_state_file))

    webhook_info = client.call("getWebhookInfo")
    if isinstance(webhook_info, dict) and webhook_info.get("url"):
        if not args.clear_webhook:
            raise RelayError(
                "Telegram webhook is configured for this bot. getUpdates will not work until the webhook is removed."
            )
        client.call(
            "deleteWebhook",
            {
                "drop_pending_updates": args.drop_pending_updates,
            },
        )

    allowed_chat_ids = {int(value) for value in args.allowed_chat_id}

    while True:
        updates = client.call(
            "getUpdates",
            {
                "offset": relay_state.offset,
                "timeout": args.poll_timeout,
                "allowed_updates": ["message"],
            },
        )
        if not isinstance(updates, list):
            raise RelayError("Telegram getUpdates returned a non-list payload")

        highest_offset = relay_state.offset
        for update in updates:
            update_id = update.get("update_id")
            if isinstance(update_id, int):
                highest_offset = max(highest_offset, update_id + 1)
            message = update.get("message")
            if isinstance(message, dict):
                handle_message(
                    message=message,
                    client=client,
                    allowed_chat_ids=allowed_chat_ids,
                    bridge_state_root=pathlib.Path(args.bridge_state_root),
                    default_project=args.project,
                )

        relay_state.offset = highest_offset
        relay_state.save()

        if args.once:
            return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="den-telegram-relay")
    subparsers = parser.add_subparsers(dest="command", required=True)

    poll = subparsers.add_parser("poll")
    poll.add_argument("--bot-token", required=True)
    poll.add_argument("--telegram-api-base", default=DEFAULT_API_BASE)
    poll.add_argument("--bridge-state-root", default=str(DEFAULT_BRIDGE_STATE_ROOT))
    poll.add_argument("--relay-state-file", default=str(DEFAULT_RELAY_STATE_ROOT / "telegram-offset.json"))
    poll.add_argument("--allowed-chat-id", action="append", default=[], required=True)
    poll.add_argument("--project")
    poll.add_argument("--poll-timeout", type=int, default=30)
    poll.add_argument("--once", action="store_true")
    poll.add_argument("--clear-webhook", action="store_true")
    poll.add_argument("--drop-pending-updates", action="store_true")

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    try:
        if args.command == "poll":
            return run_poll(args)
    except (RelayError, urllib.error.URLError, OSError, json.JSONDecodeError) as exc:
        print(f"den-telegram-relay: {exc}", file=os.sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
